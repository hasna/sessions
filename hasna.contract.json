{
  "$schema": "https://github.com/hasna/contracts/schema/hasna.service_contract.v1.json",
  "schema": "hasna.service_contract.v1",
  "name": "sessions",
  "class": "service",
  "contractVersion": "v1",
  "kitVersion": "0.5.2",
  "description": "Search and sync AI coding sessions (Claude, Codex, Codewith, Gemini). Local mode uses SQLite at ~/.hasna/sessions/sessions.db; cloud storage mode (HASNA_SESSIONS_STORAGE_MODE=cloud) is PURE REMOTE per Amendment A1 — sessions-serve reads/writes shared Postgres directly for session metadata, imported messages, and tool calls via /v1 including /v1/sessions/import.",
  "bins": [
    "sessions",
    "sessions-mcp",
    "sessions-serve"
  ],
  "deploymentModes": [
    "local",
    "self-hosted"
  ],
  "serviceSurfaces": [
    {
      "name": "http",
      "status": "supported",
      "bin": "sessions-serve",
      "mcpBin": "sessions-mcp",
      "authMode": "api-key",
      "deploymentModes": [
        "local",
        "self-hosted"
      ],
      "health": {
        "method": "GET",
        "path": "/health",
        "public": true
      },
      "readiness": {
        "method": "GET",
        "path": "/ready",
        "public": true
      },
      "version": {
        "method": "GET",
        "path": "/version",
        "public": true
      },
      "apiBasePath": "/v1",
      "openApiPath": "/openapi.json"
    }
  ],
  "storage": {
    "mode": "local",
    "envPrefix": "HASNA_SESSIONS_",
    "aliasEnvPrefix": "SESSIONS_",
    "databaseUrlSecretRef": "hasna/oss/sessions/database-url",
    "sqlitePath": "~/.hasna/sessions/sessions.db"
  },
  "metadata": {
    "serve": {
      "healthEndpoints": [
        "/health",
        "/ready",
        "/version"
      ],
      "versionedApiPrefix": "/v1",
      "openapi": "/openapi.json",
      "auth": "api-key (@hasna/contracts/auth)"
    },
    "sessionSources": [
      "claude",
      "codex",
      "codewith",
      "gemini"
    ]
  }
}
